{
    "name": "mortogo321/laravel-notify",
    "description": "A Laravel package for sending notifications and alerts to multiple providers",
    "version": "2.0.0",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "notification",
        "alert",
        "slack",
        "discord",
        "telegram",
        "line",
        "email"
    ],
    "authors": [
        {
            "name": "Mor",
            "email": "mortogo321@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Mortogo321\\LaravelNotify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mortogo321\\LaravelNotify\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "pint": "vendor/bin/pint",
        "stan": "vendor/bin/phpstan analyse",
        "quality": [
            "@pint",
            "@stan",
            "@test"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mortogo321\\LaravelNotify\\NotifyServiceProvider"
            ],
            "aliases": {
                "Notify": "Mortogo321\\LaravelNotify\\Facades\\Notify"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
